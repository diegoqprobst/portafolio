# Copy this to .env.local and fill in your values
# ---------------------------------------------------------------------------
# INSFORGE
# ---------------------------------------------------------------------------
INSFORGE_URL=https://<app-key>.<region>.insforge.app
# or for local: INSFORGE_URL=http://localhost:7130

# ---------------------------------------------------------------------------
# ADMIN AUTH
# ---------------------------------------------------------------------------
# Generate JWT secret:   openssl rand -base64 32
JWT_SECRET=your-secret-here

# Generate password hash (run in terminal):
#   node -e "require('bcryptjs').hash('YOUR_PASSWORD',12).then(console.log)"
ADMIN_EMAIL=diegoaquinde@gmail.com
ADMIN_PASSWORD_HASH=$2b$12$...

# ---------------------------------------------------------------------------
# AI PROVIDERS  (set at least one)
# ---------------------------------------------------------------------------
# OpenAI — gpt-4o-mini (cheaper, fast) — preferred when set
OPENAI_API_KEY=sk-...

# Anthropic — claude-sonnet-4-6 (better reasoning, prompt caching)
ANTHROPIC_API_KEY=sk-ant-...
